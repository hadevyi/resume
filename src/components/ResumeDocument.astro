---
import type { ResumeLanguage, ResumeTrack } from '../data/resume';
import { instructorResumeContent, resumeContent, resumeMeta } from '../data/resume';
import resumeDownloads from '../data/resumeDownloads.json';

interface Props {
  language: ResumeLanguage;
  track?: ResumeTrack;
}

const { language, track = 'developer' } = Astro.props;
const content = track === 'instructor' ? instructorResumeContent[language] : resumeContent[language];
const trackMeta = resumeMeta[track];
const lastUpdated = '2026.06.16';

const sectionOrder = trackMeta.sectionOrder[language] as readonly string[];

const orderedSections = [...(content.sections ?? [])].sort((a, b) => {
  const aIndex = sectionOrder.indexOf(a.title);
  const bIndex = sectionOrder.indexOf(b.title);

  return (aIndex === -1 ? Number.MAX_SAFE_INTEGER : aIndex) - (bIndex === -1 ? Number.MAX_SAFE_INTEGER : bIndex);
});

const skillAnchorTitles = trackMeta.skillAnchorTitles[language] as readonly string[];

const skillAnchorIndex = Math.max(
  ...skillAnchorTitles.map((title) => orderedSections.findIndex((section) => section.title === title))
);
const skillInsertIndex = skillAnchorIndex >= 0 ? skillAnchorIndex + 1 : 0;
const sectionsBeforeSkills = orderedSections.slice(0, skillInsertIndex);
const sectionsAfterSkills = orderedSections.slice(skillInsertIndex);

const languageLinks =
  track === 'instructor'
    ? {
        ko: '/resume/instructor/ko',
        en: '/resume/instructor/en'
      }
    : {
        ko: '/resume/ko',
        en: '/resume/en'
      };

const downloadDocument = resumeDownloads.find((document) => document.track === track && document.language === language);
const downloadPdf = downloadDocument ? `/resume/downloads/${downloadDocument.fileName}` : null;

const downloadLabel = language === 'ko' ? 'PDF 다운로드' : 'Download PDF';
const profilePhoto = 'photo' in content.profile ? content.profile.photo : null;
const developerPrivateDocumentNote =
  track === 'developer'
    ? language === 'ko'
      ? "상세 기술 경험은 비공개 '경력기술서'로 별도 관리하며, 필요 시 제출할 수 있습니다."
      : 'Detailed technical experience is managed separately and can be provided when needed.'
    : null;
const resumeUsageNotice =
  language === 'ko'
    ? '본 이력서는 제출 및 검토 목적의 열람만 허용됩니다.\n별도 허가 없는 대량 크롤링, 무단 수집, 복제, 재배포, 재사용, 사칭 및 허위 사용은 금합니다.\n위반 시 민형사상 책임을 포함한 관련 법적 조치를 진행할 수 있습니다.'
    : 'This resume may be viewed only for submission and review purposes.\nBulk crawling, unauthorized collection, copying, redistribution, reuse, impersonation, or false use without permission is prohibited.\nViolations may result in legal action, including civil and criminal liability.';
const resumeAnalyticsNotice =
  language === 'ko'
    ? '본 이력서 페이지는 방문 통계 확인을 위해 Google Analytics를 사용할 수 있습니다.\nGoogle Analytics는 방문 페이지, 접속 환경, 대략적인 지역 정보 등 비식별 분석 데이터를 수집할 수 있습니다.\n수집된 데이터는 이력서 열람 현황을 파악하고 페이지 사용성을 개선하는 목적으로만 활용됩니다.'
    : 'This resume page may use Google Analytics to review visit statistics.\nGoogle Analytics may collect non-identifying analytics data such as visited pages, access environment, and approximate location information.\nCollected data is used only to understand resume page views and improve page usability.';
const copyrightNotice = '© 2026 Dang Hyeona. All rights reserved.';
const usageNoticeLabel = language === 'ko' ? '이용 및 저작권 안내' : 'Usage and copyright notice';
const analyticsNoticeLabel = language === 'ko' ? '분석 도구 안내' : 'Analytics notice';

const now = new Date();

const parsePeriodMonth = (value: string) => {
  if (value === '현재' || value.toLowerCase() === 'present') {
    return { year: now.getFullYear(), month: now.getMonth() + 1 };
  }

  const match = value.match(/(\d{4})[./-](\d{1,2})/);

  if (!match) {
    return null;
  }

  return {
    year: Number(match[1]),
    month: Number(match[2])
  };
};

const getDurationMonths = (period: string) => {
  const [startText, endText] = period.split(/\s*-\s*/);
  const start = parsePeriodMonth(startText);
  const end = parsePeriodMonth(endText ?? startText);

  if (!start || !end) {
    return null;
  }

  return (end.year - start.year) * 12 + (end.month - start.month) + 1;
};

const formatDuration = (months: number | null, targetLanguage: ResumeLanguage = language) => {
  if (!months || months < 1) {
    return null;
  }

  const years = Math.floor(months / 12);
  const restMonths = months % 12;

  if (targetLanguage === 'en') {
    const yearText = years > 0 ? `${years} ${years === 1 ? 'yr' : 'yrs'}` : '';
    const monthText = restMonths > 0 ? `${restMonths} ${restMonths === 1 ? 'mo' : 'mos'}` : '';

    if (years === 0) {
      return `${months} ${months === 1 ? 'mo' : 'mos'}`;
    }

    return [yearText, monthText].filter(Boolean).join(' ');
  }

  if (years === 0) {
    return `${months}개월`;
  }

  if (restMonths === 0) {
    return `${years}년`;
  }

  return `${years}년 ${restMonths}개월`;
};

const isCareerSection = (title: string) =>
  ['경력', 'Experience', '실무 및 교육 경력', 'Professional & Teaching Experience'].includes(title);

const getCareerTotalDuration = (section: (typeof orderedSections)[number]) => {
  if (!isCareerSection(section.title)) {
    return null;
  }

  const totalMonths = section.items.reduce((sum, item) => sum + (getDurationMonths(item.period) ?? 0), 0);

  return formatDuration(totalMonths);
};

const getSectionDurationSummary = (section: (typeof orderedSections)[number]) => {
  if ('durationSummary' in section && section.durationSummary) {
    return section.durationSummary;
  }

  const totalDuration = getCareerTotalDuration(section);

  if (!totalDuration) {
    return null;
  }

  return `${language === 'ko' ? '총' : 'Total'} ${totalDuration}`;
};

const getSectionClassName = (section: (typeof orderedSections)[number]) =>
  `resume-section-list${isCareerSection(section.title) ? ' resume-section-list--career' : ''}`;
---

<div class={`resume-document resume-document--${track} space-y-12`}>
  <section class={`resume-hero resume-hero--${track} ${profilePhoto ? 'resume-hero--with-photo' : ''}`}>
    <div class="resume-hero-content">
      <div class="resume-hero-heading">
        <p class="eyebrow">{language === 'ko' ? '이력서' : 'Resume'}</p>
        <h1 class="type-display text-ink">
          {content.profile.name}
        </h1>
      </div>
      <div class="resume-hero-copy">
        <p class="type-subsection-title whitespace-pre-line text-ink">{content.profile.headline}</p>
        <p class="type-body max-w-3xl whitespace-pre-line text-ink/72">{content.profile.summary}</p>
      </div>
    </div>
    <div class="resume-hero-side">
      {
        profilePhoto && (
          <figure class={`resume-portrait resume-portrait--${track}`}>
            <img src={profilePhoto.src} alt={profilePhoto.alt} loading="eager" decoding="async" />
          </figure>
        )
      }
    </div>
  </section>

  {
    sectionsBeforeSkills.map((section) => (
      <section class={getSectionClassName(section)}>
        <h2 class="type-section-title text-ink">
          {section.title}
          {getSectionDurationSummary(section) && (
            <span class="resume-section-duration">{getSectionDurationSummary(section)}</span>
          )}
        </h2>
        <div class="resume-timeline">
          {
            section.items.map((item) => (
              <article class="resume-timeline-item">
                <div class="resume-timeline-meta">
                  <p class="resume-timeline-period">{item.period}</p>
                  {isCareerSection(section.title) && formatDuration(getDurationMonths(item.period)) && (
                    <p class="resume-timeline-duration">({formatDuration(getDurationMonths(item.period))})</p>
                  )}
                  {'employmentType' in item && item.employmentType && (
                    <p class="resume-timeline-employment">{item.employmentType}</p>
                  )}
                </div>
                <div class="resume-timeline-body">
                  <h3 class="resume-timeline-title">{item.title}</h3>
                  {'description' in item && item.description && (
                    <p class="resume-timeline-description">{item.description}</p>
                  )}
                  {'details' in item && item.details && (
                    <ul class="resume-timeline-details">
                      {item.details.map((detail) => (
                        <li>{detail}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>
    ))
  }

  {
    content.skillGroups.length > 0 && (
      <section class="space-y-4">
        <h2 class="type-section-title text-ink">
          {content.labels.skills}
        </h2>
        <div class="skill-list-grid">
          {content.skillGroups.map((group) => (
            <article class="skill-list-item">
              <h3 class="skill-list-title">{group.label}</h3>
              <p class="skill-list-text">{group.items.join(', ')}</p>
            </article>
          ))}
        </div>
      </section>
    )
  }

  {
    sectionsAfterSkills.map((section) => (
      <section class={getSectionClassName(section)}>
        <h2 class="type-section-title text-ink">
          {section.title}
          {getSectionDurationSummary(section) && (
            <span class="resume-section-duration">{getSectionDurationSummary(section)}</span>
          )}
        </h2>
        <div class="resume-timeline">
          {
            section.items.map((item) => (
              <article class="resume-timeline-item">
                <div class="resume-timeline-meta">
                  <p class="resume-timeline-period">{item.period}</p>
                  {isCareerSection(section.title) && formatDuration(getDurationMonths(item.period)) && (
                    <p class="resume-timeline-duration">({formatDuration(getDurationMonths(item.period))})</p>
                  )}
                  {'employmentType' in item && item.employmentType && (
                    <p class="resume-timeline-employment">{item.employmentType}</p>
                  )}
                </div>
                <div class="resume-timeline-body">
                  <h3 class="resume-timeline-title">{item.title}</h3>
                  {'description' in item && item.description && (
                    <p class="resume-timeline-description">{item.description}</p>
                  )}
                  {'details' in item && item.details && (
                    <ul class="resume-timeline-details">
                      {item.details.map((detail) => (
                        <li>{detail}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </section>
    ))
  }

  <div
    class="resume-document-meta"
    data-print="hidden"
    aria-label={language === 'ko' ? '문서 정보' : 'Document information'}
  >
    <div class="resume-document-meta-row resume-document-meta-row--primary">
      <p class="resume-document-meta-copyright">{copyrightNotice}</p>
      {developerPrivateDocumentNote && <p class="resume-document-meta-note">{developerPrivateDocumentNote}</p>}
    </div>
    <div class="resume-document-meta-row resume-document-meta-row--secondary">
      <div class="resume-document-meta-notices">
        <details class="resume-document-meta-notice">
          <summary>{usageNoticeLabel}</summary>
          <p>{resumeUsageNotice}</p>
        </details>
        <span class="resume-document-meta-separator" aria-hidden="true">|</span>
        <details class="resume-document-meta-notice">
          <summary>{analyticsNoticeLabel}</summary>
          <p>{resumeAnalyticsNotice}</p>
        </details>
      </div>
      <div class="resume-document-meta-controls">
        <span>{content.lastUpdatedLabel} {lastUpdated}</span>
        <span aria-hidden="true">·</span>
        {
          (['ko', 'en'] as const).map((item, index) => (
            <>
              {index > 0 && <span aria-hidden="true">|</span>}
              {
                item === language ? (
                  <span class="resume-language-current" aria-current="true">{item.toUpperCase()}</span>
                ) : (
                  <a class="resume-language-link" href={languageLinks[item]} hreflang={item}>
                    {item.toUpperCase()}
                  </a>
                )
              }
            </>
          ))
        }
      </div>
    </div>
  </div>

  {
    downloadPdf && (
      <a
        class="resume-floating-download"
        href={downloadPdf}
        download
        data-print="hidden"
        aria-label={downloadLabel}
        title={downloadLabel}
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="resume-floating-download-icon">
          <path d="M12 4v11" />
          <path d="m7.5 10.5 4.5 4.5 4.5-4.5" />
          <path d="M6 19h12" />
        </svg>
        <span>PDF</span>
      </a>
    )
  }
</div>

<script>
  document.querySelectorAll('.resume-document-meta-notices').forEach((group) => {
    group.querySelectorAll('details').forEach((details) => {
      details.addEventListener('toggle', () => {
        if (!details.open) return;

        group.querySelectorAll('details').forEach((item) => {
          if (item !== details) item.removeAttribute('open');
        });

        requestAnimationFrame(() => {
          const target = details.querySelector('p') ?? details;
          const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          target.scrollIntoView({
            block: 'end',
            inline: 'nearest',
            behavior: prefersReducedMotion ? 'auto' : 'smooth'
          });
        });
      });
    });
  });
</script>
