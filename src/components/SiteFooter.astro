---
import { siteMeta } from '../data/site';

const ecosystemLinks = [
  {
    href: 'https://hadevyi.github.io/',
    label: '공식 홈페이지'
  },
  {
    href: 'https://hadevyi.github.io/resume/',
    label: '이력서'
  },
  {
    href: 'https://hadevyi.github.io/portfolio/',
    label: '포트폴리오'
  },
  {
    href: 'https://hadevyi.github.io/experience/',
    label: '경험 정리'
  },
  {
    href: 'https://hadevyi.github.io/blog/',
    label: '블로그'
  }
] as const;

const contactEmail = 'hadevyi@gmail.com';
const usageNotice =
  '정상적인 검색 엔진의 공개 페이지 색인은 허용하지만, 별도 허가 없는 대량 크롤링, 무단 수집, 복제, 재배포, 재사용은 금합니다.';
---

<footer class="site-footer" data-print="hidden">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-2 px-5 py-4 sm:px-8 lg:px-10">
    <div class="flex flex-col gap-1.5 md:flex-row md:items-center md:justify-between">
      <p class="type-caption text-ink/55">
        <span class="font-medium text-ink/78">{siteMeta.brand}</span>
        <span class="mx-2 text-ink/28">·</span>
        문의
        <a href={`mailto:${contactEmail}`} class="footer-inline-link ml-1">
          {contactEmail}
        </a>
      </p>

      <nav class="type-caption flex flex-wrap gap-x-4 gap-y-1" aria-label="Hadevyi 사이트 링크">
        {
          ecosystemLinks.map((item) => {
            const isCurrent = item.href === siteMeta.siteUrl;

            return (
              <a
                href={item.href}
                aria-current={isCurrent ? 'page' : undefined}
                class:list={[isCurrent ? 'footer-inline-link-current' : 'footer-inline-link']}
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>
    </div>

    <p class="type-micro border-t border-ink/10 pt-2 text-ink/36">
      {usageNotice}
    </p>
  </div>
</footer>
